# Saarthi secrets-only env template.
#
# Non-secret defaults should go in local `config.py` (copy from `config.example.py`).
# Environment variables still override config.py when present.

# AUTH (secret)
ADMIN_TOKEN=

# EMAIL AUTH (secret)
SMTP_APP_PASSWORD=

# BACKUP AUTH (secret)
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
VIDWIZ_DB_URL=
TRACKCROW_DB_URL=

# NTFY AUTH (secret)
NTFY_TOKEN=

# Optional non-secret overrides (prefer config.py unless needed)
# APP_NAME=
# LOCATION_DB_PATH=
# GEOFENCE_MAPPING_PATH=
# LOG_LEVEL=
# EMAIL_ENABLED=
# NTFY_ENABLED=
# WHATSAPP_ENABLED=
# WHATSAPP_SSH_HOST=
# WHATSAPP_REMOTE_SCRIPT_PATH=
# WHATSAPP_TARGET_FAMILY=
# WHATSAPP_TARGET_PERSONAL=
# WHATSAPP_TIMEOUT_SECONDS=
# SMTP_EMAIL=
# SMTP_HOST=
# SMTP_PORT=
# GEOFENCE_UPDATES_RECIPIENT=
# GEOFENCE_SENDER_NAME=
# GEOFENCE_SUBJECT_TEMPLATE=
# GEOFENCE_EMAIL_TEMPLATE=
# GEOFENCE_WHATSAPP_TEMPLATE=
# BACKUP_BUCKET=
# VIDWIZ_S3_PREFIX=
# TRACKCROW_S3_PREFIX=
# VIDWIZ_DUMP_FILENAME=
# TRACKCROW_DUMP_FILENAME=
# NTFY_BASE_URL=
# NTFY_TOPIC=
# GDRIVE_SOURCE=
# GDRIVE_DESTINATION=
# GDRIVE_FOLDERS=
